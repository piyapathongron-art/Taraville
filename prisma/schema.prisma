// This is your Prisma schema file,
// learn more about it in the docs: [https://pris.ly/d/prisma-schema](https://pris.ly/d/prisma-schema)

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// Employees
// ==========================================
model Employee {
  employeeId Int        @id @default(autoincrement())
  firstName  String     @db.VarChar(50)
  lastName   String     @db.VarChar(50)
  phone      String     @unique @db.VarChar(10)
  email      String?    @db.VarChar(30)
  department Department @default(Employee)
  salary     Decimal?   @db.Decimal(10, 2)
  address    String?    @db.Text
  imageUrl   String?    @db.VarChar(255)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user        User?
  assignments Assignment[]
}

enum Department {
  Sale
  Engineer
  Staff
  Employee
}

// Users
// ==========================================
model User {
  userId   Int    @id @default(autoincrement())
  empId    Int    @unique
  password String @db.VarChar(255)
  role     Role   @default(User)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  employee  Employee        @relation(fields: [empId], references: [employeeId])
  surveys   ProjectSurvey[]
  auditLogs AuditLog[]
}

enum Role {
  User
  Staff
  Admin
}

// Houses & House Images
// ==========================================
model House {
  houseId     Int      @id @default(autoincrement())
  houseCode   String?  @unique @db.VarChar(20)
  houseName   String?  @db.VarChar(100)
  projectName String?  @db.VarChar(100)
  houseType   String?  @db.VarChar(100)
  price       Decimal? @db.Decimal(12, 2)
  status      HStatus?
  details     String?  @db.Text

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  assignments Assignment[]
  images      HouseImage[]
}

model HouseImage {
  imageId  Int     @id @default(autoincrement())
  houseId  Int
  imageUrl String  @db.VarChar(255)
  isCover  Boolean @default(false)

  createdAt DateTime @default(now())

  house House @relation(fields: [houseId], references: [houseId], onDelete: Cascade)
}

enum HStatus {
  Available
  Book
  Sold
  Repair
  Building
}

// Assignments
// ==========================================
model Assignment {
  assignmentId    Int       @id @default(autoincrement())
  houseId         Int
  empId           Int
  taskTitle       String?   @db.VarChar(100)
  taskDescription String?   @db.Text
  dutyRole        String?   @db.VarChar(100)
  assignedDate    DateTime? @db.Date
  status          Status    @default(Pending)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  house    House    @relation(fields: [houseId], references: [houseId])
  employee Employee @relation(fields: [empId], references: [employeeId])
}

enum Status {
  Confirming
  Pending
  Complete
}

// Customers 
// ==========================================
model Customer {
  customerId  Int     @id @default(autoincrement())
  firstName   String  @db.VarChar(100)
  lastName    String  @db.VarChar(100)
  phone       String  @unique @db.VarChar(20)
  lineId      String? @db.VarChar(50)
  email       String? @db.VarChar(100)
  houseNo     String? @db.VarChar(50)
  street      String? @db.VarChar(100)
  subDistrict String? @db.VarChar(100)
  district    String? @db.VarChar(100)
  province    String? @db.VarChar(100)
  zipcode     String? @db.VarChar(10)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  surveys ProjectSurvey[]
}

// Project Surveys
// ==========================================
model ProjectSurvey {
  surveyId               Int        @id @default(autoincrement())
  customerId             Int
  userId                 Int?
  surveyType             SurveyType @default(Online)
  visitDate              DateTime?  @db.Date
  gender                 String?    @db.VarChar(20)
  occupation             String?    @db.VarChar(100)
  incomeRange            String?    @db.VarChar(100)
  interestedPropertyType String?    @db.VarChar(100)
  preferredBedroom       Int?
  preferredBathroom      Int?
  familySize             String?    @db.VarChar(50)
  expectedBudget         String?    @db.VarChar(100)
  informationSource      String?    @db.VarChar(255)
  installmentCapacity    String?    @db.VarChar(100)
  remark                 String?    @db.Text

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  customer        Customer          @relation(fields: [customerId], references: [customerId], onDelete: Cascade)
  user            User?             @relation(fields: [userId], references: [userId], onDelete: SetNull)
  decisionFactors DecisionFactors[]
}

enum SurveyType {
  Online
  Walkin
}

// Audit Logs
// ==========================================
model AuditLog {
  logId     Int      @id @default(autoincrement())
  userId    Int?
  action    Action
  tableName String   @db.VarChar(100)
  recordId  Int
  oldData   Json?
  newData   Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [userId], onDelete: SetNull)
}

enum Action {
  CREATE
  UPDATE
  SOFTDELETE
  HARDDELETE
}

model DecisionFactors {
  id             Int     @id @default(autoincrement())
  surveyId       Int
  decisionFactor String?

  survey ProjectSurvey @relation(fields: [surveyId], references: [surveyId], onDelete: Cascade)
}
